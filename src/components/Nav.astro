---
import { NAV_ITEMS, SITE } from '../lib/site';
const path = Astro.url.pathname;
---

<header class="border-b border-line/60">
  <div class="container-page flex items-center justify-between py-6 md:py-7">
    <a
      href="/"
      class="font-display text-xl tracking-tight text-ink hover:text-accent transition-colors duration-200"
    >
      {SITE.name}
    </a>

    <nav class="hidden md:block" aria-label="Navegación principal">
      <ul class="flex items-center gap-8 text-[15px] text-ink-soft">
        {NAV_ITEMS.map((item) => {
          const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'transition-colors duration-200 hover:text-ink',
                  active && 'text-ink',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <a
      href="/contacto"
      class="hidden md:inline-flex items-center gap-1 text-[15px] text-ink border-b border-ink pb-0.5 hover:text-accent hover:border-accent transition-colors duration-200"
    >
      Agendar
    </a>

    <button
      type="button"
      class="md:hidden text-ink"
      aria-label="Abrir menú"
      data-mobile-toggle
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="4" y1="8" x2="20" y2="8" />
        <line x1="4" y1="16" x2="20" y2="16" />
      </svg>
    </button>
  </div>

  <div
    class="hidden md:hidden border-t border-line/60 bg-bg"
    data-mobile-menu
  >
    <nav class="container-page py-6" aria-label="Navegación móvil">
      <ul class="flex flex-col gap-4 text-lg text-ink">
        {NAV_ITEMS.map((item) => (
          <li>
            <a href={item.href} class="block py-1">{item.label}</a>
          </li>
        ))}
        <li>
          <a href="/contacto" class="block py-1 text-accent">Agendar →</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

---
interface FaqItem {
  question: string;
  answer: string;
  id?: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-line/80">
  {items.map((item) => (
    <details class="group py-6" id={item.id}>
      <summary class="flex cursor-pointer items-start justify-between gap-6 list-none">
        <h3 class="text-headline text-ink pr-6">{item.question}</h3>
        <span
          class="mt-2 flex h-6 w-6 shrink-0 items-center justify-center text-ink-soft transition-transform duration-200 group-open:rotate-45"
          aria-hidden="true"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 5v14M5 12h14" />
          </svg>
        </span>
      </summary>
      <div class="mt-4 max-w-prose text-ink-soft text-[17px] leading-relaxed">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>

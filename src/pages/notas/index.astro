---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { SITE } from '../../lib/site';
import { getCollection } from 'astro:content';
import { buildBreadcrumbSchema } from '../../lib/schema';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const [featured, ...rest] = posts;

const breadcrumb = buildBreadcrumbSchema([
  { name: 'Inicio', url: SITE.url },
  { name: 'Notas', url: `${SITE.url}/notas` },
]);
---

<BaseLayout
  title="Notas sobre parejas y vínculos — Juan Cruz Resch"
  description="Notas sobre vínculos, comunicación, decisiones y crisis de pareja. Lecturas para parejas y profesionales, escritas por el Lic. Juan Cruz Resch desde la mirada sistémica."
  extraSchemas={[breadcrumb]}
>
  <div class="container-page pt-12">
    <nav aria-label="Migas de pan" class="text-caption text-ink-muted">
      <a href="/" class="hover:text-ink transition-colors duration-200">Inicio</a>
      <span class="mx-2">›</span>
      <span class="text-ink">Notas</span>
    </nav>
  </div>

  <section class="container-page pt-12 pb-section">
    <div class="max-w-3xl">
      <h1 class="text-section text-ink">Notas sobre parejas.</h1>
      <p class="mt-8 text-lead">
        Lo que voy escribiendo sobre vínculos, comunicación, decisiones y
        crisis. Notas largas, sin urgencia.
      </p>
    </div>
  </section>

  {featured && (
    <section class="container-page pb-section">
      <ArticleCard
        href={`/notas/${featured.slug}`}
        title={featured.data.title}
        description={featured.data.description}
        date={featured.data.pubDate.toISOString()}
        readingTime={featured.data.readingTime}
        category={featured.data.category}
        image={featured.data.heroImage}
        featured={true}
      />
    </section>
  )}

  {rest.length > 0 && (
    <section class="container-page pb-section">
      <div class="border-t border-line/60">
        {rest.map((post) => (
          <ArticleCard
            href={`/notas/${post.slug}`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.pubDate.toISOString()}
            readingTime={post.data.readingTime}
            category={post.data.category}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import DataTable from '../components/DataTable.astro';
import { SITE } from '../lib/site';
import { buildServiceSchema, buildBreadcrumbSchema } from '../lib/schema';
import { buildWaUrl } from '../lib/whatsapp';

const url = `${SITE.url}/terapia-online`;
const breadcrumb = buildBreadcrumbSchema([
  { name: 'Inicio', url: SITE.url },
  { name: 'Terapia online', url },
]);
const service = buildServiceSchema({
  name: 'Terapia online (individual y adolescentes)',
  description:
    'Terapia individual y para adolescentes online en español con el Lic. Juan Cruz Resch. Atención por videollamada a personas de toda LatAm.',
  url,
});
---

<BaseLayout
  title="Terapia online en español — Juan Cruz Resch | LatAm"
  description="Terapia individual y para adolescentes online en español con el Lic. Juan Cruz Resch. Atención por videollamada a personas de toda LatAm. Enfoque sistémico."
  extraSchemas={[service, breadcrumb]}
>
  <div class="container-page pt-12">
    <nav aria-label="Migas de pan" class="text-caption text-ink-muted">
      <a href="/" class="hover:text-ink transition-colors duration-200">Inicio</a>
      <span class="mx-2">›</span>
      <span class="text-ink">Terapia online</span>
    </nav>
  </div>

  <section class="container-page pt-12 pb-section">
    <div class="max-w-3xl">
      <h1 class="text-section text-ink">
        Terapia online en español, donde estés.
      </h1>
      <p class="mt-8 text-lead">
        Sesiones individuales para adultos y adolescentes desde los 12
        años, por videollamada. Mismo encuadre, misma duración y mismos
        honorarios que la modalidad presencial. Enfoque sistémico
        integrativo. Atiendo a personas hispanohablantes en toda LatAm.
      </p>
    </div>
  </section>

  <section class="container-page py-section">
    <SectionHeading kicker="Cobertura" title="Zonas donde atiendo." />
    <div class="mt-group max-w-4xl">
      <DataTable
        headers={['Región', 'Zona horaria', 'Disponibilidad']}
        rows={[
          ['Argentina', 'GMT-3', 'Amplia'],
          ['Uruguay', 'GMT-3', 'Amplia'],
          ['Chile', 'GMT-3 / GMT-4', 'Amplia'],
          ['Paraguay · Bolivia', 'GMT-3 / GMT-4', 'Amplia'],
          ['Perú · Colombia · Ecuador', 'GMT-5', 'Tarde-noche'],
          ['México', 'GMT-6', 'Tarde-noche'],
          ['España', 'GMT+1', 'Mañana Olavarría'],
        ]}
      />
    </div>
  </section>

  <section class="container-page py-section">
    <SectionHeading kicker="Logística" title="Cómo funciona." />
    <div class="mt-group max-w-prose space-y-5 text-[18px] leading-relaxed text-ink-soft">
      <p>
        Las sesiones se hacen por Google Meet o Zoom. Pido un espacio
        privado, con buena conexión y sin interrupciones — el encuadre de
        la sesión depende de eso.
      </p>
      <p>
        Honorarios para terapia individual y adolescente: <strong class="text-ink">{SITE.pricing.individual} ARS</strong> por sesión de {SITE.sessionDuration.individual} minutos. Mismo precio que presencial.
      </p>
      <p>
        Aceptamos transferencia, Mercado Pago y Wise (para pacientes fuera
        de Argentina).
      </p>
      <p class="text-[15px] text-ink-muted">
        Honorarios actualizados a {SITE.pricing.actualizado}.
      </p>
    </div>
  </section>

  <section class="container-page py-section">
    <SectionHeading kicker="Una nota" title="¿Y la terapia de pareja online?" />
    <div class="mt-group max-w-prose space-y-5 text-[18px] leading-relaxed text-ink-soft">
      <p>
        La terapia de pareja la trabajo principalmente en modalidad
        presencial. Hay información clínica — gestos, silencios, distancia
        corporal — que en pareja es central y que la pantalla recorta. Por
        eso, online priorizo procesos individuales y de adolescentes.
      </p>
      <p>
        Si vivís fuera de Olavarría y querés consultar por pareja,
        escribime y vemos caso por caso.
      </p>
    </div>
  </section>

  <section class="container-page py-section">
    <div class="max-w-4xl">
      <h2 class="text-section text-ink">
        Agendá una primera sesión.
      </h2>
      <div class="mt-10">
        <a href={buildWaUrl('online')} class="btn-primary" rel="noopener" target="_blank">
          Escribir por WhatsApp
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

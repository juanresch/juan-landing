---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import DataTable from '../components/DataTable.astro';
import { SITE } from '../lib/site';
import { buildServiceSchema, buildBreadcrumbSchema } from '../lib/schema';
import { buildWaUrl } from '../lib/whatsapp';

const url = `${SITE.url}/terapia-individual`;
const breadcrumb = buildBreadcrumbSchema([
  { name: 'Inicio', url: SITE.url },
  { name: 'Terapia individual', url },
]);
const service = buildServiceSchema({
  name: 'Terapia individual',
  description:
    'Terapia individual con orientación clínica con el Lic. Juan Resch. Presencial en Olavarría y online en toda LatAm.',
  url,
});
---

<BaseLayout
  title="Terapia individual en Olavarría y online — Juan Resch"
  description="Terapia individual con el Lic. Juan Resch. Atención presencial en Olavarría y online en toda LatAm. Procesos breves o de mediano plazo."
  extraSchemas={[service, breadcrumb]}
>
  <div class="container-page pt-12">
    <nav aria-label="Migas de pan" class="text-caption text-ink-muted">
      <a href="/" class="hover:text-ink transition-colors duration-200">Inicio</a>
      <span class="mx-2">›</span>
      <span class="text-ink">Terapia individual</span>
    </nav>
  </div>

  <section class="container-page pt-12 pb-section">
    <div class="max-w-3xl">
      <h1 class="text-section text-ink">
        Terapia individual para adultos y adolescentes.
      </h1>
      <p class="mt-8 text-lead">
        Sesiones de psicoterapia individual con un enfoque integrativo de
        base sistémica. Trabajo procesos de ansiedad, vínculos, sentido de
        vida, decisiones difíciles y desarrollo personal. Atiendo adultos y
        adolescentes desde los 12 años, presencial en Olavarría (Rivadavia
        2055) y online en toda LatAm. Soy Lic. Juan Cruz Resch, formado en
        la Universidad Nacional de Mar del Plata.
      </p>
    </div>
  </section>

  <section class="container-page py-section">
    <SectionHeading kicker="Motivos de consulta" title="Sobre qué trabajamos." />
    <ol class="mt-group max-w-3xl space-y-8">
      <li class="border-t border-line pt-6 flex gap-6">
        <span class="text-caption text-accent shrink-0 mt-1">01</span>
        <div>
          <h3 class="text-headline text-ink">Ansiedad</h3>
          <p class="mt-2 text-ink-soft leading-relaxed">
            Cuadros de ansiedad sostenida, ataques de pánico, anticipación
            constante. Trabajamos sobre el contexto en el que aparece y las
            herramientas para regularla.
          </p>
        </div>
      </li>
      <li class="border-t border-line pt-6 flex gap-6">
        <span class="text-caption text-accent shrink-0 mt-1">02</span>
        <div>
          <h3 class="text-headline text-ink">Vínculos y dinámicas relacionales</h3>
          <p class="mt-2 text-ink-soft leading-relaxed">
            Vínculos que desgastan, patrones que se repiten en distintas
            relaciones, dificultades para sostener cercanía o distancia.
          </p>
        </div>
      </li>
      <li class="border-t border-line pt-6 flex gap-6">
        <span class="text-caption text-accent shrink-0 mt-1">03</span>
        <div>
          <h3 class="text-headline text-ink">Sentido de vida y decisiones</h3>
          <p class="mt-2 text-ink-soft leading-relaxed">
            Momentos donde algo no encaja pero cuesta nombrarlo. Decisiones
            importantes — vocacionales, vinculares, geográficas — que
            requieren claridad.
          </p>
        </div>
      </li>
      <li class="border-t border-line pt-6 flex gap-6">
        <span class="text-caption text-accent shrink-0 mt-1">04</span>
        <div>
          <h3 class="text-headline text-ink">Desarrollo personal</h3>
          <p class="mt-2 text-ink-soft leading-relaxed">
            Procesos de autoconocimiento sostenidos, no vinculados a un
            síntoma agudo, sino al deseo de revisar la propia forma de
            estar en la vida.
          </p>
        </div>
      </li>
    </ol>
  </section>

  <section class="container-page py-section">
    <SectionHeading kicker="Logística" title="Modalidades y honorarios." />
    <div class="mt-group max-w-4xl">
      <DataTable
        headers={['Modalidad', 'Duración', 'Frecuencia sugerida', 'Honorarios']}
        rows={[
          ['Presencial en Olavarría', `${SITE.sessionDuration.individual} minutos`, 'Semanal', `${SITE.pricing.individual} ARS`],
          ['Online en toda LatAm', `${SITE.sessionDuration.individual} minutos`, 'Semanal', `${SITE.pricing.individual} ARS`],
        ]}
      />

      <p class="mt-4 text-caption text-ink-muted">
        Honorarios actualizados a {SITE.pricing.actualizado}.
      </p>
    </div>
  </section>

  <section class="container-page py-section">
    <div class="max-w-4xl">
      <h2 class="text-section text-ink">
        ¿Tiene sentido que hablemos?
      </h2>
      <div class="mt-10">
        <a href={buildWaUrl('individual')} class="btn-primary" rel="noopener" target="_blank">
          Escribir por WhatsApp
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
